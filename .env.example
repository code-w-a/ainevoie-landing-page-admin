# Copy to `.env.local` for local runs. Provider onboarding welcome + verification emails use SMTP via `src/lib/email.ts`:

EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
# Optional: EMAIL_SERVER_SECURE=true|false (defaults to secure for port 465)
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=
# Optional timeouts (milliseconds):
# EMAIL_CONNECTION_TIMEOUT_MS=
# EMAIL_GREETING_TIMEOUT_MS=
# EMAIL_SOCKET_TIMEOUT_MS=
