# Copiază variabilele necesare în Vercel (sau alt hosting): Project → Settings → Environment Variables.
# Vezi și functions/README_NEWSLETTER.md pentru secretele Firebase (newsletter).

# SMTP — Next.js (ex. email bun venit prestator /api/providers/onboarding)
EMAIL_SERVER_HOST=mail.ai-nevoie.ro
EMAIL_SERVER_PORT=465
EMAIL_SERVER_SECURE=true
EMAIL_SERVER_USER=no-reply@ai-nevoie.ro
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=AInevoie <no-reply@ai-nevoie.ro>
